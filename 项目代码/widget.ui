  <property name="styleSheet">
   <string notr="true">
/* 主背景 - 紫色渐变 */
Widget {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #1a0b2e, stop:1 #2d1b4e);
    font-family: &quot;Microsoft YaHei&quot;, &quot;Segoe UI&quot;, Arial, sans-serif;
}

/* 标签 */
QLabel {
    color: #e8d5ff;
    font-weight: bold;
}

/* 复选框 */
QCheckBox {
    color: #d4c4e8;
    font-size: 14px;
    spacing: 8px;
    padding: 4px;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 2px solid #9b59b6;
    background: rgba(155,89,182,0.2);
}

QCheckBox::indicator:checked {
    background: #9b59b6;
    border-color: #af7ac5;
}

QCheckBox::indicator:hover {
    border-color: #af7ac5;
}

/* 进度条 */
QProgressBar {
    border: none;
    border-radius: 10px;
    text-align: center;
    background-color: rgba(255,255,255,0.1);
    color: white;
    font-weight: bold;
}

QProgressBar::chunk {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #9b59b6, stop:1 #c39bd3);
    border-radius: 10px;
}

/* 滑块 */
QSlider::groove:horizontal {
    height: 6px;
    background: rgba(255,255,255,0.15);
    border-radius: 3px;
}

QSlider::handle:horizontal {
    background: #9b59b6;
    width: 18px;
    height: 18px;
    margin: -6px 0;
    border-radius: 9px;
}

QSlider::handle:horizontal:hover {
    background: #af7ac5;
}

QSlider::sub-page:horizontal {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #9b59b6, stop:1 #c39bd3);
    border-radius: 3px;
}

/* 数值输入框 */
QDoubleSpinBox, QTextEdit {
    background: rgba(0,0,0,0.3);
    border: 1px solid #9b59b6;
    border-radius: 8px;
    color: #d4c4e8;
    font-size: 14px;
    padding: 4px;
}

QDoubleSpinBox:focus, QTextEdit:focus {
    border-color: #af7ac5;
    background: rgba(0,0,0,0.5);
}

/* 按钮 */
QPushButton {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #9b59b6, stop:1 #7d3c98);
    color: white;
    border: none;
    border-radius: 20px;
    font-weight: bold;
    font-size: 13px;
    padding: 6px 12px;
}

QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #af7ac5, stop:1 #9b59b6);
}

QPushButton:pressed {
    background: #6c3483;
}
